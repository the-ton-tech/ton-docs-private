# Algolia search credentials.
# Dashboard: https://dashboard.algolia.com → your application → Settings → API Keys
#
# Copy this file to `.env.local` (gitignored) and fill in the values, and add
# the same variables to the Vercel project / CI secrets (see CUTOVER.md §3).

# Application ID (public).
NEXT_PUBLIC_ALGOLIA_APP_ID=

# Search-Only API Key (public — safe to ship to the browser).
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=

# Index name. Must match the index the build-time sync writes to.
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=ton-docs

# Admin (write) API Key — SECRET. Used only by scripts/sync-content.ts at
# build time. Never expose this to the browser (no NEXT_PUBLIC_ prefix).
ALGOLIA_ADMIN_API_KEY=
