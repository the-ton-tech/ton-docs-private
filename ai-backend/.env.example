# OpenRouter API key (required). Get one at https://openrouter.ai/keys
OPENROUTER_KEY=sk-or-v1-xxxxxxxx

# Model slug passed to OpenRouter. Default is a free-tier model.
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Port the service listens on (localhost only; nginx fronts it).
PORT=8787

# Source of the documentation index (Fumadocs llms-full.txt).
DOCS_LLMS_URL=https://docs.ton.org/llms-full.txt

# Global daily request cap (OpenRouter free tier is ~50 req/day).
DAILY_REQUEST_CAP=45

# Per-IP daily request cap — stops one client from draining the global cap.
PER_IP_DAILY_CAP=10

# How often (minutes) to rebuild the docs search index.
DOCS_INDEX_REFRESH_MINUTES=360

# Extra allowed CORS origins, comma-separated (exact matches).
# https://docs.ton.org and topteam Vercel previews are always allowed.
ALLOWED_ORIGINS=
